---
layout: base.njk
activeNav: poems
ogType: article
styles: |
  .poem-page { max-width: 600px; margin: 0 auto; padding: 120px 24px 0; }
  .poem-back { font-size: 13px; color: var(--tertiary); text-decoration: none; transition: color 0.2s; display: inline-block; margin-bottom: 48px; }
  .poem-back:hover { color: var(--ink); }
  .poem-header { text-align: center; margin-bottom: 40px; }
  .poem-title { font-family: var(--serif); font-size: clamp(26px, 5vw, 36px); font-weight: 500; letter-spacing: -0.01em; line-height: 1.2; margin-bottom: 8px; }
  .poem-author { font-family: var(--serif); font-size: 17px; font-style: italic; font-weight: 300; color: var(--secondary); }
  .poem-ornament { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 40px; }
  .poem-ornament span { width: 24px; height: 1px; background: var(--rule); }
  .poem-ornament svg { color: var(--gold-muted); }
  .poem-body { font-family: var(--serif); font-size: 19px; font-weight: 400; line-height: 1.8; color: var(--ink); margin-bottom: 48px; }
  .poem-body .stanza { margin-bottom: 28px; }
  .poem-body .stanza:last-child { margin-bottom: 0; }
  .poem-body em { font-style: italic; }
  .poem-share { display: flex; gap: 24px; justify-content: center; padding-top: 32px; border-top: 1px solid var(--rule); }
  .poem-share a { font-size: 13px; color: var(--tertiary); text-decoration: none; transition: color 0.2s; cursor: pointer; }
  .poem-share a:hover { color: var(--ink); }
  .poem-next { max-width: 600px; margin: 48px auto 0; padding: 0 24px; }
  .poem-next-label { font-size: 11px; color: var(--tertiary); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px; }
  .poem-next-link { display: block; text-decoration: none; color: inherit; padding: 24px; border: 1px solid var(--rule); border-radius: 8px; transition: border-color 0.2s; }
  .poem-next-link:hover { border-color: var(--rose-soft); }
  .poem-next-title { font-family: var(--serif); font-size: 18px; font-weight: 500; margin-bottom: 4px; }
  .poem-next-author { font-family: var(--serif); font-size: 14px; font-style: italic; color: var(--secondary); }
  footer { margin-top: 80px; }
  @media (max-width: 640px) { .poem-page { padding: 100px 20px 0; } .poem-body { font-size: 17px; } }
---

<article class="poem-page">
  <a href="/poems/" class="poem-back">← All poems</a>
  <header class="poem-header">
    <h1 class="poem-title">{{ title }}</h1>
    <p class="poem-author">{{ author }}</p>
  </header>
  <div class="poem-ornament"><span></span><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M4 0L4.7 3.3L8 4L4.7 4.7L4 8L3.3 4.7L0 4L3.3 3.3Z" fill="currentColor"/></svg><span></span></div>
  <div class="poem-body">
    {{ content | safe }}
  </div>
  <div class="poem-share">
    <a onclick="navigator.clipboard.writeText(window.location.href).then(function(){this.textContent='Copied!'}.bind(this))">Copy link</a>
  </div>
</article>

{% set allPoems = collections.poems %}
{% set currentIndex = 0 %}
{% for p in allPoems %}{% if p.url == page.url %}{% set currentIndex = loop.index0 %}{% endif %}{% endfor %}
{% set nextIndex = (currentIndex + 1) % allPoems.length %}
{% set nextPoem = allPoems[nextIndex] %}
{% if allPoems.length > 1 %}
<div class="poem-next">
  <p class="poem-next-label">Next poem</p>
  <a href="{{ nextPoem.url }}" class="poem-next-link">
    <p class="poem-next-title">{{ nextPoem.data.title }}</p>
    <p class="poem-next-author">{{ nextPoem.data.author }}</p>
  </a>
</div>
{% endif %}
