<script>
var stage = document.getElementById('stage');
    var textBlocks = document.querySelectorAll('.step-block');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          textBlocks.forEach(function(b) { b.classList.remove('is-active'); });
          entry.target.classList.add('is-active');
          stage.setAttribute('data-scene', entry.target.getAttribute('data-target-scene'));
        }
      });
    }, { root: null, rootMargin: '-45% 0px -45% 0px', threshold: 0 });
    textBlocks.forEach(function(block) { observer.observe(block); });
</script>