---
layout: base.njk
title: "Poems"
description: "Poetry from Jury of Poets. Poets reading poets."
activeNav: poems
permalink: /poems/index.html
styles: |
  body { min-height: 100vh; display: flex; flex-direction: column; }
  main { flex: 1; }
  .page-header { max-width: 600px; margin: 0 auto; padding: 120px 24px 20px; text-align: center; }
  .page-title { font-family: var(--serif); font-size: clamp(32px, 6vw, 48px); font-weight: 300; letter-spacing: -0.02em; margin-bottom: 8px; }
  .page-subtitle { font-family: var(--sans); font-size: 14px; color: var(--tertiary); }
  .deck-section { max-width: 480px; margin: 0 auto; padding: 40px 24px 100px; }
  .genre-tabs { display: flex; gap: 0; justify-content: center; flex-wrap: wrap; margin-top: 32px; align-items: center; line-height: 2.2; }
  .genre-tab { font-family: var(--sans); font-size: 12px; padding: 0; border: none; border-radius: 0; background: transparent; color: var(--rule); cursor: pointer; transition: color 0.2s; letter-spacing: 0.03em; }
  .genre-tab:hover { color: var(--secondary); }
  .genre-tab.active { color: var(--ink); }
  .genre-sep { color: var(--rule); font-size: 9px; margin: 0 12px; user-select: none; opacity: 0.5; }
  .deck { position: relative; height: 380px; touch-action: pan-y; }
  .poem-card { position: absolute; width: 100%; left: 0; top: 0; height: 100%; background: var(--bg); border: 1px solid var(--rule); border-radius: 8px; padding: 32px; display: flex; flex-direction: column; align-items: center; text-align: center; transition: opacity 0.4s ease, transform 0.4s ease; user-select: none; text-decoration: none; color: inherit; opacity: 0; pointer-events: none; transform: translateX(20px); }
  .poem-card.front { opacity: 1; pointer-events: auto; cursor: pointer; transform: translateX(0); z-index: 1; }
  .poem-card.front:hover { box-shadow: 0 8px 40px rgba(61, 32, 40, 0.08); border-color: var(--rose-soft); }
  .poem-card.gone-left { opacity: 0; transform: translateX(-20px); }
  .poem-card.gone-right { opacity: 0; transform: translateX(20px); }
  .pc-tags { display: flex; gap: 6px; justify-content: center; margin-bottom: 16px; }
  .pc-tag { font-size: 11px; padding: 3px 12px; border-radius: 100px; background: var(--warm); color: var(--tertiary); }
  .pc-title { font-family: var(--serif); font-size: clamp(20px, 4vw, 26px); font-weight: 500; line-height: 1.25; height: 66px; display: flex; align-items: center; justify-content: center; }
  .pc-author { font-family: var(--serif); font-size: 16px; font-style: italic; font-weight: 300; color: var(--secondary); margin: 8px 0 24px; }
  .pc-ornament { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 24px; }
  .pc-ornament span { width: 20px; height: 1px; background: var(--rule); }
  .pc-ornament svg { color: var(--gold-muted); }
  .pc-quote { font-family: var(--serif); font-size: 19px; font-weight: 300; color: var(--ink); line-height: 1.7; }
  .pc-read { font-size: 13px; color: var(--rose); transition: color 0.2s; margin-top: auto; padding-top: 20px; }
  .poem-card.front:hover .pc-read { color: var(--ink); }
  .deck-nav { display: flex; justify-content: center; gap: 6px; margin-top: 24px; align-items: center; }
  .deck-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rule); transition: background 0.3s, transform 0.3s; cursor: pointer; }
  .deck-dot.active { background: var(--ink); transform: scale(1.4); }
  .deck-arrow { width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--rule); background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; color: var(--tertiary); transition: border-color 0.2s, color 0.2s; margin: 0 8px; }
  .deck-arrow:hover { border-color: var(--rose-soft); color: var(--ink); }
  @media (max-width: 640px) { .page-header { padding: 100px 20px 16px; } .deck-section { padding: 32px 16px 80px; } .poem-card { padding: 32px 24px 28px; } }
---

<main>
  <header class="page-header">
    <h1 class="page-title">Poems</h1>
    <p class="page-subtitle">For now, enjoy some poetry by our very own Ronan.</p>
  </header>
  <section class="deck-section">
    <div class="deck" id="deck"></div>
    <div class="deck-nav" id="deck-nav"></div>
    <div class="genre-tabs" id="tabs"></div>
  </section>
</main>

<script>
  var poems = [{% for poem in collections.poems %}{ title: "{{ poem.data.title }}", author: "{{ poem.data.author }}", tags: {{ poem.data.poemTags | dump | safe }}, quote: "{{ poem.data.quote | safe }}", url: "{{ poem.url }}" }{% if not loop.last %},{% endif %}{% endfor %}];
  var allTags = {{ allTags | dump | safe }};
  var activeTag = "all", currentIndex = 0, filtered = poems.slice();
  function render() {
    filtered = activeTag === "all" ? poems.slice() : poems.filter(function(p) { return p.tags.indexOf(activeTag) !== -1; });
    if (currentIndex >= filtered.length) currentIndex = 0;
    var tabsEl = document.getElementById("tabs");
    tabsEl.innerHTML = "";
    allTags.forEach(function(tag, i) {
      var btn = document.createElement("button");
      btn.className = "genre-tab" + (tag === activeTag ? " active" : "");
      btn.textContent = tag;
      btn.onclick = function() { activeTag = tag; currentIndex = 0; render(); };
      tabsEl.appendChild(btn);
      if (i < allTags.length - 1) { var sep = document.createElement("span"); sep.className = "genre-sep"; sep.textContent = "\u00b7"; tabsEl.appendChild(sep); }
    });
    var deckEl = document.getElementById("deck");
    deckEl.innerHTML = "";
    if (filtered.length === 0) {
      var empty = document.createElement("div");
      empty.style.cssText = "display:flex;align-items:center;justify-content:center;height:100%;text-align:center;";
      empty.innerHTML = '<div><p style="font-family:var(--serif);font-size:20px;font-style:italic;color:var(--tertiary);margin-bottom:8px;">Poems incoming.</p><p style="font-size:13px;color:var(--tertiary);">Nothing in <strong>' + activeTag + '</strong> yet — but there will be.</p></div>';
      deckEl.appendChild(empty);
    } else {
      filtered.forEach(function(poem, i) {
        var card = document.createElement("a");
        card.href = poem.url;
        card.className = "poem-card";
        if (i === currentIndex) card.classList.add("front");
        else if (i < currentIndex) card.classList.add("gone-left");
        else card.classList.add("gone-right");
        card.innerHTML = '<div class="pc-tags">' + poem.tags.map(function(t) { return '<span class="pc-tag">' + t + '</span>'; }).join("") + '</div><h2 class="pc-title">' + poem.title + '</h2><p class="pc-author">' + poem.author + '</p><div class="pc-ornament"><span></span><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M4 0L4.7 3.3L8 4L4.7 4.7L4 8L3.3 4.7L0 4L3.3 3.3Z" fill="currentColor"/></svg><span></span></div><p class="pc-quote">' + poem.quote + '</p><p class="pc-read">Read the poem \u2192</p>';
        deckEl.appendChild(card);
      });
    }
    var navEl = document.getElementById("deck-nav");
    navEl.innerHTML = "";
    if (filtered.length > 1) {
      var prev = document.createElement("button"); prev.className = "deck-arrow"; prev.innerHTML = "\u2190";
      prev.onclick = function(e) { e.preventDefault(); currentIndex = (currentIndex - 1 + filtered.length) % filtered.length; render(); };
      navEl.appendChild(prev);
      filtered.forEach(function(_, i) { var dot = document.createElement("span"); dot.className = "deck-dot" + (i === currentIndex ? " active" : ""); dot.onclick = function() { currentIndex = i; render(); }; navEl.appendChild(dot); });
      var next = document.createElement("button"); next.className = "deck-arrow"; next.innerHTML = "\u2192";
      next.onclick = function(e) { e.preventDefault(); currentIndex = (currentIndex + 1) % filtered.length; render(); };
      navEl.appendChild(next);
    }
  }
  render();
  var startX = 0, deckEl = document.getElementById("deck");
  deckEl.addEventListener("touchstart", function(e) { startX = e.touches[0].clientX; }, { passive: true });
  deckEl.addEventListener("touchend", function(e) { var diff = startX - e.changedTouches[0].clientX; if (Math.abs(diff) > 50 && filtered.length > 1) { if (diff > 0) currentIndex = (currentIndex + 1) % filtered.length; else currentIndex = (currentIndex - 1 + filtered.length) % filtered.length; render(); } }, { passive: true });
  var scrollCooldown = false;
  deckEl.addEventListener("wheel", function(e) { if (scrollCooldown || filtered.length <= 1) return; if (Math.abs(e.deltaY) > 20) { e.preventDefault(); scrollCooldown = true; if (e.deltaY > 0) currentIndex = (currentIndex + 1) % filtered.length; else currentIndex = (currentIndex - 1 + filtered.length) % filtered.length; render(); setTimeout(function() { scrollCooldown = false; }, 400); } }, { passive: false });
  document.addEventListener("keydown", function(e) { if (filtered.length <= 1) return; if (e.key === "ArrowRight" || e.key === "ArrowDown") { currentIndex = (currentIndex + 1) % filtered.length; render(); } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") { currentIndex = (currentIndex - 1 + filtered.length) % filtered.length; render(); } });
</script>
